// TODO: Reglas de seguridad Firestore (producción) - Player 1 (Backend)
// Paso 1: Definir reglas por colección (wells, evaluations, users)
// Paso 2: Validar custom claims (rol del usuario)
// Paso 3: Validar ownership (usuario es dueño del pozo)
// Entregable: Solo usuarios autenticados con rol válido pueden leer/escribir
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // TODO: Regla para colección users
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // TODO: Regla para colección wells
    match /wells/{wellId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && 
                     request.auth.token.role in ['OPERADOR', 'SUP_CAMPO', 'SUP_MAYOR'];
      allow update, delete: if request.auth != null && 
                             request.auth.token.role in ['SUP_CAMPO', 'SUP_MAYOR', 'COORDINADOR', 'GERENTE'];
    }
    
    // TODO: Regla para colecciones evaluations, approvals, lectures
    match /evaluations/{evalId} {
      allow read, write: if request.auth != null;
    }
  }
}
