rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function getRole() {
      return request.auth.token.rol;
    }

    function isRoot()     { return getRole() == 'ROOT'; }
    function isGerente()  { return getRole() == 'GERENTE'; }
    function isSupMayor() { return getRole() == 'SUP_MAYOR'; }
    function isSupCampo() { return getRole() == 'SUP_CAMPO'; }
    function isOperador() { return getRole() == 'OPERADOR'; }
    function isSupervisor() {
      return isSupCampo() || isSupMayor() || isGerente();
    }

    function isAssignedToPozo(pozoId) {
      return request.auth.token.pozosAsignados.hasAny([pozoId]);
    }

    // /usuarios/{uid} — perfil del usuario
    match /usuarios/{uid} {
      allow read: if request.auth != null;
      allow write: if isRoot();
    }

    // /pozos/{pozoId} — configuración de pozos
    match /pozos/{pozoId} {
      allow read: if request.auth != null;
      allow create, update: if isRoot() || isSupervisor();
      allow delete: if isRoot();
    }

    // /evaluaciones/{evalId} — sesiones de medición
    match /evaluaciones/{evalId} {
      allow read: if request.auth != null;
      allow create: if isRoot() ||
        (isOperador() && isAssignedToPozo(request.resource.data.pozoId));
      allow update: if isRoot() || isSupervisor() ||
        (isOperador() && resource.data.operadorId == request.auth.uid
                       && resource.data.estado == 'EN_CURSO');
      allow delete: if isRoot();

      // /evaluaciones/{evalId}/lecturas/{lecturaId}
      match /lecturas/{lecturaId} {
        allow read: if request.auth != null;
        allow create: if isRoot() ||
          (isOperador() &&
           get(/databases/$(database)/documents/evaluaciones/$(evalId)).data.operadorId == request.auth.uid);
        allow update, delete: if isRoot();
      }
    }

    // /logs/{logId} — auditoría, solo lectura/escritura de sistema
    match /logs/{logId} {
      allow read: if isRoot();
      allow write: if false; // solo Cloud Functions con Admin SDK
    }
  }
}
