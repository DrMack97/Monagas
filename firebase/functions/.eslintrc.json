{
  // TODO: ESLint para Cloud Functions - Player 3 (Fullstack)
  // Paso 1: Extender eslint:recommended y typescript/recommended
  // Paso 2: Configurar parser @typescript-eslint/parser
  // Entregable: pnpm lint en functions no muestra errores
  "extends": [
    "eslint:recommended",
    "plugin:@typescript-eslint/recommended"
  ],
  "parser": "@typescript-eslint/parser",
  "plugins": ["@typescript-eslint"],
  "rules": {
    "@typescript-eslint/no-unused-vars": ["error", { "argsIgnorePattern": "^_" }],
    "@typescript-eslint/no-explicit-any": "warn"
  }
}
