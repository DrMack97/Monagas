{
  "compilerOptions": {
    "module": "commonjs",
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "outDir": "./lib",
    "sourceMap": true,
    "strict": true,
    "target": "ES2020",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@monagas/core/*": ["../../packages/core/src/*"],
      "@monagas/core": ["../../packages/core/src/index.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "lib", "tests"]
}