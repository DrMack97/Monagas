rules_version = '2';

// ⚠️ SOLO PARA EL EMULADOR LOCAL — NUNCA DESPLEGAR A PRODUCCIÓN
// Estas reglas permiten cualquier lectura/escritura a un usuario autenticado
// para poder iterar rápido sin tropezar con permisos mientras desarrollas.

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
